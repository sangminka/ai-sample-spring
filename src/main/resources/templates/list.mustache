{{! Model Key: boardList(List<BoardResponse.Min>), currentPage(Integer), pageSize(Integer), offset(Integer), boardCount(Integer) }}
{{> layout/header}}

<main class="site-container">
    <section class="board-page">
        <div class="board-page__intro">
            <span class="eyebrow">
                <i class="fa-solid fa-table-list"></i>
                Step 2
            </span>
            <h1 class="board-page__title">LIMIT 3와 OFFSET으로 페이지가 바뀌는 원리 학습</h1>
            <p class="board-page__description">
                이번 단계에서는 게시글을 한 번에 전부 가져오지 않고, SQL에서 세 개만 잘라 옵니다.
                주소창의 <code>?page=0</code>, <code>?page=1</code>, <code>?page=2</code> 값을 바꾸면
                <strong>offset = page * limit</strong> 계산 결과에 따라 다른 3건이 보입니다.
            </p>
        </div>

        <section class="board-page__summary" aria-label="pagination summary">
            <div class="board-page__chip">
                <span>page</span>
                <strong>{{currentPage}}</strong>
            </div>
            <div class="board-page__chip">
                <span>limit</span>
                <strong>{{pageSize}}</strong>
            </div>
            <div class="board-page__chip">
                <span>offset</span>
                <strong>{{offset}}</strong>
            </div>
            <div class="board-page__chip">
                <span>rows</span>
                <strong>{{boardCount}}</strong>
            </div>
        </section>

        <section class="board-list-card" aria-labelledby="board-list-title">
            <div class="board-list-card__header">
                <h2 id="board-list-title">현재 페이지 게시글 3건 조회</h2>
                <p>
                    아직 이전/다음 버튼은 넣지 않았습니다.
                    먼저 SQL이 데이터를 어떻게 자르는지 확인하고, 다음 단계에서 이동 버튼을 붙입니다.
                </p>
                <div class="board-page__formula">
                    <span>offset = page * limit</span>
                    <strong>{{offset}} = {{currentPage}} * {{pageSize}}</strong>
                </div>
            </div>

            <div class="board-list-table" role="list">
                <div class="board-list-table__head" aria-hidden="true">
                    <span>번호</span>
                    <span>제목</span>
                    <span>작성자</span>
                    <span>작성일</span>
                </div>

                {{#boardList}}
                <a class="board-line" role="listitem" href="/board/{{id}}?page={{currentPage}}">
                    <span class="board-line__id">#{{id}}</span>
                    <span class="board-line__title">{{title}}</span>
                    <span class="board-line__author">{{username}}</span>
                    <span class="board-line__date">{{createdAtText}}</span>
                </a>
                {{/boardList}}

                {{^boardList}}
                <div class="board-line board-line--empty">
                    <span>이 페이지에는 게시글이 없습니다.</span>
                </div>
                {{/boardList}}
            </div>
        </section>
    </section>
</main>

{{> layout/footer}}
