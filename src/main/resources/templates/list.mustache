{{! Model Key: model(BoardResponse.ListResponse) }}
{{> layout/header}}

<main class="site-container">
    <section class="board-page">
        <div class="board-page__intro">
            <span class="eyebrow">
                <i class="fa-solid fa-table-list"></i>
                Step 4
            </span>
            <h1 class="board-page__title">COUNT(*)와 전체 개수로 총 페이지 수를 계산하는 페이징 학습</h1>
            <p class="board-page__description">
                이번 단계에서는 <code>COUNT(*)</code>로 전체 게시글 수를 구하고,
                그 값을 바탕으로 총 페이지 수와 페이지 번호 목록을 계산합니다.
                이제는 <strong>현재 페이지 결과 3건</strong>만 보는 것이 아니라
                <strong>전체 몇 페이지가 있는지</strong>까지 함께 화면에서 확인할 수 있습니다.
            </p>
        </div>

        <section class="board-page__summary" aria-label="pagination summary">
            <div class="board-page__chip">
                <span>page</span>
                <strong>{{model.paging.currentPage}}</strong>
            </div>
            <div class="board-page__chip">
                <span>limit</span>
                <strong>{{model.paging.pageSize}}</strong>
            </div>
            <div class="board-page__chip">
                <span>offset</span>
                <strong>{{model.paging.offset}}</strong>
            </div>
            <div class="board-page__chip">
                <span>rows</span>
                <strong>{{model.paging.boardCount}}</strong>
            </div>
            <div class="board-page__chip">
                <span>total</span>
                <strong>{{model.paging.totalCount}}</strong>
            </div>
            <div class="board-page__chip">
                <span>pages</span>
                <strong>{{model.paging.totalPageCount}}</strong>
            </div>
        </section>

        <section class="board-list-card" aria-labelledby="board-list-title">
            <div class="board-list-card__header">
                <h2 id="board-list-title">현재 페이지 게시글과 전체 페이지 번호 목록</h2>
                <p>
                    이제 목록 아래에서 전체 페이지 번호를 한 번에 확인할 수 있습니다.
                    현재 페이지는 강조해서 보여주고, 다른 페이지 번호를 누르면 해당 목록으로 이동합니다.
                    마지막 페이지를 넘는 주소는 강제로 되돌리지 않고 빈 목록으로 렌더링합니다.
                </p>
                <div class="board-page__formula">
                    <span>total pages = ceil(total count / page size)</span>
                    <strong>{{model.paging.totalPageCount}} = ceil({{model.paging.totalCount}} / {{model.paging.pageSize}})</strong>
                </div>
            </div>

            <div class="board-list-table" role="list">
                <div class="board-list-table__head" aria-hidden="true">
                    <span>번호</span>
                    <span>제목</span>
                    <span>작성자</span>
                    <span>작성일</span>
                </div>

                {{#model.boards}}
                <a class="board-line" role="listitem" href="/board/{{id}}?page={{model.paging.currentPage}}">
                    <span class="board-line__id">#{{id}}</span>
                    <span class="board-line__title">{{title}}</span>
                    <span class="board-line__author">{{username}}</span>
                    <span class="board-line__date">{{createdAtText}}</span>
                </a>
                {{/model.boards}}

                {{^model.boards}}
                <div class="board-line board-line--empty">
                    <span>이 페이지에는 게시글이 없습니다.</span>
                </div>
                {{/model.boards}}
            </div>

            <div class="board-pagination">
                <div class="board-pagination__status">
                    <span>현재 페이지</span>
                    <strong>{{model.paging.currentPage}}</strong>
                </div>
                <div class="board-pagination__actions">
                    {{#model.paging.hasPrev}}
                    <form method="get" action="/board/list" class="board-pagination__form">
                        <input type="hidden" name="page" value="{{model.paging.prevPage}}">
                        <button class="button button--secondary" type="submit">
                            <i class="fa-solid fa-arrow-left"></i>
                            이전
                        </button>
                    </form>
                    {{/model.paging.hasPrev}}

                    {{#model.paging.hasNext}}
                    <form method="get" action="/board/list" class="board-pagination__form">
                        <input type="hidden" name="page" value="{{model.paging.nextPage}}">
                        <button class="button" type="submit">
                            다음
                            <i class="fa-solid fa-arrow-right"></i>
                        </button>
                    </form>
                    {{/model.paging.hasNext}}
                </div>
                <div class="board-pagination__numbers" aria-label="페이지 번호 목록">
                    {{#model.paging.pageNumbers}}
                    {{#current}}
                    <span class="page-number page-number--active">{{number}}</span>
                    {{/current}}

                    {{^current}}
                    <a href="/board/list?page={{number}}" class="page-number">{{number}}</a>
                    {{/current}}
                    {{/model.paging.pageNumbers}}
                </div>
            </div>
        </section>
    </section>
</main>

{{> layout/footer}}
