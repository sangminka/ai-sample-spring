{{! Model Key: model(BoardResponse.ListResponse) }}
{{> layout/header}}

<main class="site-container">
    <section class="board-page">
        <div class="board-page__intro">
            <span class="eyebrow">
                <i class="fa-solid fa-table-list"></i>
                Step 4
            </span>
            <h1 class="board-page__title">COUNT(*)와 전체 개수로 총 페이지 수를 계산하는 페이징 학습</h1>
            <p class="board-page__description">
                이번 단계에서는 <code>COUNT(*)</code>로 전체 게시글 수를 구하고,
                그 값을 바탕으로 총 페이지 수와 페이지 번호 목록을 계산합니다.
                이제는 <strong>현재 페이지 결과 3건</strong>만 보는 것이 아니라
                <strong>전체 몇 페이지가 있는지</strong>까지 함께 화면에서 확인할 수 있습니다.
            </p>
        </div>

        <section class="board-list-card" aria-labelledby="board-search-title">
            <div class="board-list-card__header">
                <h2 id="board-search-title">게시글 검색</h2>
                <p>제목 또는 내용에 포함된 키워드를 입력하고 SSR 방식으로 검색합니다.</p>
                <form method="get" action="/board/list" class="row g-2 align-items-end">
                    <input type="hidden" name="page" value="1">
                    <div class="col-12 col-md-9">
                        <label class="form-label" for="keyword">검색어</label>
                        <input id="keyword"
                            type="text"
                            name="keyword"
                            class="form-control"
                            value="{{model.keyword}}"
                            placeholder="제목 또는 내용을 입력하세요">
                    </div>
                    <div class="col-12 col-md-3">
                        <button class="button w-100" type="submit">
                            <i class="fa-solid fa-magnifying-glass"></i>
                            검색
                        </button>
                    </div>
                </form>
                <div class="mt-3" aria-live="polite">
                    <p id="board-search-loading" class="text-secondary mb-1" hidden>검색 중...</p>
                    <p id="board-search-error" class="text-danger mb-0" hidden></p>
                </div>
            </div>
        </section>

        <div id="board-search-results" data-api-url="/api/board/search">
        <section class="board-page__summary" aria-label="pagination summary">
            <div class="board-page__chip">
                <span>page</span>
                <strong>{{model.paging.currentPage}}</strong>
            </div>
            <div class="board-page__chip">
                <span>limit</span>
                <strong>{{model.paging.pageSize}}</strong>
            </div>
            <div class="board-page__chip">
                <span>offset</span>
                <strong>{{model.paging.offset}}</strong>
            </div>
            <div class="board-page__chip">
                <span>rows</span>
                <strong>{{model.paging.boardCount}}</strong>
            </div>
            <div class="board-page__chip">
                <span>total</span>
                <strong>{{model.paging.totalCount}}</strong>
            </div>
            <div class="board-page__chip">
                <span>pages</span>
                <strong>{{model.paging.totalPageCount}}</strong>
            </div>
            {{#model.hasKeyword}}
            <div class="board-page__chip">
                <span>keyword</span>
                <strong>{{model.keyword}}</strong>
            </div>
            {{/model.hasKeyword}}
        </section>

        <section class="board-list-card" aria-labelledby="board-list-title">
            <div class="board-list-card__header">
                <h2 id="board-list-title">현재 페이지 게시글과 최대 5개 페이지 번호 목록</h2>
                <p>
                    이제 목록 아래에서 현재 구간의 페이지 번호를 최대 5개까지 확인할 수 있습니다.
                    현재 페이지는 강조해서 보여주고, 다른 페이지 번호를 누르면 해당 목록으로 이동합니다.
                    `이전`과 `다음` 버튼으로 다른 페이지로 이동하고, 마지막 페이지를 넘는 주소는 강제로 되돌리지 않고 빈 목록으로 렌더링합니다.
                </p>
                <div class="board-page__formula">
                    <span>total pages = ceil(total count / page size)</span>
                    <strong>{{model.paging.totalPageCount}} = ceil({{model.paging.totalCount}} / {{model.paging.pageSize}})</strong>
                </div>
            </div>

            <div class="board-list-table" role="list">
                <div class="board-list-table__head" aria-hidden="true">
                    <span>번호</span>
                    <span>제목</span>
                    <span>작성자</span>
                    <span>작성일</span>
                </div>

                {{#model.boards}}
                <a class="board-line"
                    role="listitem"
                    href="/board/{{id}}?page={{model.paging.currentPage}}{{#model.hasKeyword}}&keyword={{model.encodedKeyword}}{{/model.hasKeyword}}">
                    <span class="board-line__id">#{{id}}</span>
                    <span class="board-line__title">{{title}}</span>
                    <span class="board-line__author">{{username}}</span>
                    <span class="board-line__date">{{createdAtText}}</span>
                </a>
                {{/model.boards}}

                {{^model.boards}}
                <div class="board-line board-line--empty">
                    {{#model.hasKeyword}}
                    <span>'{{model.keyword}}' 검색 결과가 없습니다.</span>
                    {{/model.hasKeyword}}
                    {{^model.hasKeyword}}
                    <span>이 페이지에는 게시글이 없습니다.</span>
                    {{/model.hasKeyword}}
                </div>
                {{/model.boards}}
            </div>

            <div class="board-pagination">
                <div class="board-pagination__status">
                    <span>현재 페이지</span>
                    <strong>{{model.paging.currentPage}}</strong>
                </div>
                <div class="board-pagination__actions">
                    {{#model.paging.hasPrev}}
                    <form method="get" action="/board/list" class="board-pagination__form">
                        <input type="hidden" name="page" value="{{model.paging.prevPage}}">
                        {{#model.hasKeyword}}
                        <input type="hidden" name="keyword" value="{{model.keyword}}">
                        {{/model.hasKeyword}}
                        <button class="button button--secondary" type="submit">
                            <i class="fa-solid fa-arrow-left"></i>
                            이전
                        </button>
                    </form>
                    {{/model.paging.hasPrev}}

                    {{#model.paging.hasNext}}
                    <form method="get" action="/board/list" class="board-pagination__form">
                        <input type="hidden" name="page" value="{{model.paging.nextPage}}">
                        {{#model.hasKeyword}}
                        <input type="hidden" name="keyword" value="{{model.keyword}}">
                        {{/model.hasKeyword}}
                        <button class="button" type="submit">
                            다음
                            <i class="fa-solid fa-arrow-right"></i>
                        </button>
                    </form>
                    {{/model.paging.hasNext}}
                </div>
                <div class="board-pagination__numbers" aria-label="페이지 번호 목록">
                    {{#model.paging.pageNumbers}}
                    {{#current}}
                    <span class="page-number page-number--active">{{number}}</span>
                    {{/current}}

                    {{^current}}
                    <a href="/board/list?page={{number}}{{#model.hasKeyword}}&keyword={{model.encodedKeyword}}{{/model.hasKeyword}}"
                        class="page-number">{{number}}</a>
                    {{/current}}
                    {{/model.paging.pageNumbers}}
                </div>
            </div>
        </section>
        </div>
    </section>
</main>

<script src="/js/board-search.js"></script>
{{> layout/footer}}
