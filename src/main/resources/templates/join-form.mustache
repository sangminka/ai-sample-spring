{{! Model Key: 없음. 현재 화면은 Fetch API 기반으로 동작합니다. }}
{{> layout/header}}

<main class="site-container">
    <section class="join-hero">
        <div class="join-hero__intro">
            <span class="eyebrow">
                <i class="fa-solid fa-user-plus"></i>
                Membership Finalize
            </span>
            <h1 class="join-hero__title">중복 체크, 공통 검증, BCrypt 저장까지 한 번에 완료하는 회원가입</h1>
            <p class="join-hero__description">
                아이디 중복 확인으로 시작해 AOP 공통 유효성 검사, 비밀번호 BCrypt 암호화, 실제 저장까지 이어지는
                전체 회원가입 프로세스를 완성했습니다. 지금 화면은 학습용 설명과 실사용 흐름을 함께 담은 최종 버전입니다.
            </p>

            <div class="join-pipeline" aria-label="회원가입 흐름">
                <div class="join-pipeline__step">
                    <strong>1. Check</strong>
                    <span>아이디 중복 확인</span>
                </div>
                <div class="join-pipeline__step">
                    <strong>2. Validate</strong>
                    <span>AOP 공통 유효성 검사</span>
                </div>
                <div class="join-pipeline__step">
                    <strong>3. Encrypt</strong>
                    <span>BCrypt 해시 암호화</span>
                </div>
                <div class="join-pipeline__step">
                    <strong>4. Save</strong>
                    <span>회원 정보 저장</span>
                </div>
            </div>
        </div>

        <section class="join-card" aria-labelledby="join-form-title">
            <div class="join-card__header">
                <h2 id="join-form-title">회원가입</h2>
                <p>필수 입력값을 채우고 가입하기를 누르면, 서버가 검증과 암호화까지 마친 뒤 회원 정보를 저장합니다.</p>
            </div>

            <form class="join-form" onsubmit="return false;">
                <div class="join-form__row join-form__row--username">
                    <label class="form-field" for="username">
                        <span class="form-field__label">아이디</span>
                        <input
                            id="username"
                            name="username"
                            class="form-field__input"
                            type="text"
                            placeholder="예: cos1234"
                            autocomplete="username">
                        <span class="form-field__helper">4자 이상 20자 이하의 영문자/숫자만 허용합니다.</span>
                    </label>

                    <div class="join-form__username-action">
                        <button id="username-check-button" class="button button--secondary" type="button">
                            <i class="fa-solid fa-magnifying-glass"></i>
                            중복 체크
                        </button>
                    </div>
                </div>

                <div class="status-panel" aria-live="polite">
                    <p id="username-status" class="status-panel__message">
                        아직 중복 체크를 실행하지 않았습니다.
                    </p>
                </div>

                <label class="form-field" for="password">
                    <span class="form-field__label">비밀번호</span>
                    <input
                        id="password"
                        name="password"
                        class="form-field__input"
                        type="password"
                        placeholder="4자 이상 입력"
                        autocomplete="new-password">
                    <span class="form-field__helper">입력 직후 서버에서 BCrypt 해시로 암호화되어 저장됩니다.</span>
                </label>

                <label class="form-field" for="email">
                    <span class="form-field__label">이메일</span>
                    <input
                        id="email"
                        name="email"
                        class="form-field__input"
                        type="email"
                        placeholder="예: demo@example.com"
                        autocomplete="email">
                </label>

                <div class="join-form__grid">
                    <label class="form-field" for="postcode">
                        <span class="form-field__label">우편번호</span>
                        <input
                            id="postcode"
                            name="postcode"
                            class="form-field__input"
                            type="text"
                            placeholder="예: 06236">
                    </label>

                    <label class="form-field" for="address">
                        <span class="form-field__label">기본 주소</span>
                        <input
                            id="address"
                            name="address"
                            class="form-field__input"
                            type="text"
                            placeholder="예: 서울시 강남구 테헤란로">
                    </label>
                </div>

                <div class="join-form__grid">
                    <label class="form-field" for="detailAddress">
                        <span class="form-field__label">상세 주소</span>
                        <input
                            id="detailAddress"
                            name="detailAddress"
                            class="form-field__input"
                            type="text"
                            placeholder="예: 101호">
                    </label>

                    <label class="form-field" for="extraAddress">
                        <span class="form-field__label">참고 항목</span>
                        <input
                            id="extraAddress"
                            name="extraAddress"
                            class="form-field__input"
                            type="text"
                            placeholder="예: 테헤란로">
                    </label>
                </div>

                <div class="join-form__submit">
                    <button id="join-submit-button" class="button button--primary" type="button">
                        <i class="fa-solid fa-check"></i>
                        가입하기
                    </button>
                </div>

                <div class="status-panel" aria-live="polite">
                    <p id="join-status" class="status-panel__message">
                        아직 회원가입을 실행하지 않았습니다.
                    </p>
                </div>
            </form>

            <section class="join-guide" aria-labelledby="fetch-guide-title">
                <h3 id="fetch-guide-title">최종 가입 흐름</h3>
                <ol class="join-guide__list">
                    <li>사용자가 회원가입 입력값을 채운다.</li>
                    <li>브라우저가 JoinDTO 형태로 `/api/users/join`에 요청을 보낸다.</li>
                    <li>AOP가 컨트롤러 진입 전에 DTO의 validate 메서드를 공통 실행한다.</li>
                    <li>서비스가 비밀번호를 BCrypt로 암호화하고 회원 정보를 저장한다.</li>
                    <li>성공 시 가입 완료 메시지를, 실패 시 400 오류 메시지를 화면에 보여준다.</li>
                </ol>
            </section>
        </section>
    </section>
</main>

<script>
    const usernameInput = document.getElementById("username");
    const passwordInput = document.getElementById("password");
    const emailInput = document.getElementById("email");
    const postcodeInput = document.getElementById("postcode");
    const addressInput = document.getElementById("address");
    const detailAddressInput = document.getElementById("detailAddress");
    const extraAddressInput = document.getElementById("extraAddress");
    const usernameCheckButton = document.getElementById("username-check-button");
    const joinSubmitButton = document.getElementById("join-submit-button");
    const usernameStatus = document.getElementById("username-status");
    const joinStatus = document.getElementById("join-status");

    function renderStatus(target, message, type) {
        target.textContent = message;
        target.dataset.state = type;
    }

    async function checkUsername() {
        const username = usernameInput.value.trim();

        // 빈 입력은 서버 요청 전에 먼저 막아 비동기 흐름의 출발 조건을 분명하게 보여준다.
        if (!username) {
            renderStatus(usernameStatus, "아이디를 먼저 입력해주세요.", "warning");
            usernameInput.focus();
            return;
        }

        renderStatus(usernameStatus, "서버에 아이디 중복 여부를 확인하는 중입니다...", "loading");

        try {
            const response = await fetch(`/api/usernames/check?username=${encodeURIComponent(username)}`);
            const responseBody = await response.json();
            const result = responseBody.body;

            renderStatus(usernameStatus, result.message, result.available ? "success" : "error");
        } catch (error) {
            renderStatus(usernameStatus, "중복 체크 중 오류가 발생했습니다. 잠시 후 다시 시도해주세요.", "error");
        }
    }

    async function submitJoin() {
        const payload = {
            username: usernameInput.value.trim(),
            password: passwordInput.value,
            email: emailInput.value.trim(),
            postcode: postcodeInput.value.trim(),
            address: addressInput.value.trim(),
            detailAddress: detailAddressInput.value.trim(),
            extraAddress: extraAddressInput.value.trim()
        };

        renderStatus(joinStatus, "서버에 회원가입 입력값 유효성 검사를 요청하는 중입니다...", "loading");

        try {
            const response = await fetch("/api/users/join", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(payload)
            });
            const responseBody = await response.json();

            if (response.ok) {
                const savedUser = responseBody.body.user;
                renderStatus(joinStatus, `${responseBody.body.message} (${savedUser.username}, ${savedUser.email})`, "success");
                passwordInput.value = "";
                return;
            }

            renderStatus(joinStatus, responseBody.msg, "error");
        } catch (error) {
            renderStatus(joinStatus, "회원가입 검증 중 오류가 발생했습니다. 잠시 후 다시 시도해주세요.", "error");
        }
    }

    usernameCheckButton.addEventListener("click", checkUsername);
    joinSubmitButton.addEventListener("click", submitJoin);
    usernameInput.addEventListener("keydown", function(event) {
        if (event.key === "Enter") {
            checkUsername();
        }
    });
</script>

{{> layout/footer}}
