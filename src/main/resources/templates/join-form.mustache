{{> layout/header}}

<main class="site-container">
    <section class="join-hero">
        <div class="join-hero__intro">
            <span class="eyebrow">
                <i class="fa-solid fa-user-plus"></i>
                Membership Step 1
            </span>
            <h1 class="join-hero__title">회원가입 전 아이디 중복 여부를 먼저 확인해보세요</h1>
            <p class="join-hero__description">
                이번 단계에서는 회원 저장보다 먼저, Fetch API를 사용해 서버와 비동기로 대화하는 흐름을 익히는 데 집중합니다.
                버튼을 누르면 페이지를 새로고침하지 않고 서버에 요청을 보내고, 응답 결과를 바로 화면에 반영합니다.
            </p>
        </div>

        <section class="join-card" aria-labelledby="join-form-title">
            <div class="join-card__header">
                <h2 id="join-form-title">아이디 중복 체크</h2>
                <p>입력 -> 요청 -> 응답 -> 화면 반영 흐름을 한 번에 볼 수 있는 Step 1 화면입니다.</p>
            </div>

            <form class="join-form" onsubmit="return false;">
                <label class="form-field" for="username">
                    <span class="form-field__label">아이디</span>
                    <input
                        id="username"
                        name="username"
                        class="form-field__input"
                        type="text"
                        placeholder="예: cos1234"
                        autocomplete="username">
                </label>

                <div class="join-form__actions">
                    <button id="username-check-button" class="button button--primary" type="button">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        중복 체크
                    </button>
                </div>

                <div class="status-panel" aria-live="polite">
                    <p id="username-status" class="status-panel__message">
                        아직 중복 체크를 실행하지 않았습니다.
                    </p>
                </div>
            </form>

            <section class="join-guide" aria-labelledby="fetch-guide-title">
                <h3 id="fetch-guide-title">Fetch API 흐름</h3>
                <ol class="join-guide__list">
                    <li>사용자가 아이디를 입력한다.</li>
                    <li>브라우저가 `/api/usernames/check`로 요청을 보낸다.</li>
                    <li>서버가 중복 여부를 JSON으로 응답한다.</li>
                    <li>자바스크립트가 응답을 읽고 화면 메시지를 즉시 바꾼다.</li>
                </ol>
            </section>
        </section>
    </section>
</main>

<script>
    const usernameInput = document.getElementById("username");
    const usernameCheckButton = document.getElementById("username-check-button");
    const usernameStatus = document.getElementById("username-status");

    function renderStatus(message, type) {
        usernameStatus.textContent = message;
        usernameStatus.dataset.state = type;
    }

    async function checkUsername() {
        const username = usernameInput.value.trim();

        // 빈 입력은 서버 요청 전에 먼저 막아 비동기 흐름의 출발 조건을 분명하게 보여준다.
        if (!username) {
            renderStatus("아이디를 먼저 입력해주세요.", "warning");
            usernameInput.focus();
            return;
        }

        renderStatus("서버에 아이디 중복 여부를 확인하는 중입니다...", "loading");

        try {
            const response = await fetch(`/api/usernames/check?username=${encodeURIComponent(username)}`);
            const responseBody = await response.json();
            const result = responseBody.body;

            renderStatus(result.message, result.available ? "success" : "error");
        } catch (error) {
            renderStatus("중복 체크 중 오류가 발생했습니다. 잠시 후 다시 시도해주세요.", "error");
        }
    }

    usernameCheckButton.addEventListener("click", checkUsername);
    usernameInput.addEventListener("keydown", function(event) {
        if (event.key === "Enter") {
            checkUsername();
        }
    });
</script>

{{> layout/footer}}
