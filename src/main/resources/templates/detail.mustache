{{! Model Key: model(BoardResponse.DetailResponse) }}
{{> layout/header}}

<main class="site-container">
    <section class="board-detail-page">
        <div class="board-detail-card">
            <div class="board-detail-card__header">
                <span class="eyebrow">
                    <i class="fa-solid fa-book-open"></i>
                    Detail
                </span>
                <h1 class="board-detail-card__title">{{model.board.title}}</h1>
                <div class="board-detail-card__meta">
                    <span>작성자 {{model.board.username}}</span>
                    <span>작성일 {{model.board.createdAtText}}</span>
                    <span>번호 #{{model.board.id}}</span>
                </div>
            </div>

            <article class="board-detail-card__content">
                {{model.board.content}}
            </article>

            <div class="board-detail-card__actions">
                <a class="button button--secondary" href="/board/list?page={{model.page}}">
                    <i class="fa-solid fa-arrow-left"></i>
                    목록으로 돌아가기
                </a>
            </div>
        </div>
    </section>
</main>

{{> layout/footer}}
